# ── Subscribe form → Google Sheet ────────────────────────────
# Google Apps Script web app URL. Deploy the script in docs/google-sheet-subscribe.md
# and paste the resulting /exec URL here.
VITE_SUBSCRIBE_WEBHOOK_URL=

# ── Contact form → Resend (server-side) ─────────────────────
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=
# Must be a verified sender on your Resend account. Use onboarding@resend.dev for dev.
CONTACT_FROM_EMAIL=onboarding@resend.dev
# Where contact form submissions are delivered.
CONTACT_TO_EMAIL=tim@50elixir.com
